import java.util.*;
class Main{
    public static void main(String[] arg){
        int r=3;
        for(int i=0;i<r;i++){
            for(int s=0;s<r-i-1;s++){
                System.out.print(" ");
            }
            for(int j=0;j<=i;j++){
                System.out.print("* ");
            }
            System.out.println();
        }
    }
}
